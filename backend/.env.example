# Application
APP_NAME=Todo Agent API
APP_VERSION=1.0.0
DEBUG=true

# Database
# For default postgres user:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/todoagent
# For macOS user with Homebrew PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://kunjal:YOUR_PASSWORD@localhost:5432/todoagent
# For PostgreSQL.app (no password):
DATABASE_URL=postgresql+asyncpg://kunjal@localhost:5432/todoagent

# JWT Settings
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# CORS (frontend URLs)
CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider Configuration
# Options: "openrouter" or "openai"
PROVIDER=openrouter

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# Override default model (optional)
# MODEL_NAME=anthropic/claude-3.5-sonnet
